{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Session Manager",
  "version": "0.1.10",
  "identifier": "dev.zeiber.session-manager",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../ui && npm run dev",
    "beforeBuildCommand": "cd ../ui && npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Session Manager",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "label": "main"
      },
      {
        "label": "popover",
        "title": "Session Manager Popover",
        "width": 340,
        "height": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "macOSPrivateApi": false,
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' tauri: data: asset: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' tauri:; connect-src 'self' tauri: ipc: http://ipc.localhost https://github.com https://*.githubusercontent.com"
    },
    "trayIcon": {
      "id": "tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright (c) 2026",
    "targets": ["app", "dmg", "msi", "nsis", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/0xKurt/session-manager/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyRjkxMzZEM0Y4NDlDNEIKUldSTG5JUS9iUlA1a3JTY285VXpzbXBuTnYzdDhPZ2p5OTNCTTFzN0VRamJqQ2F0ODFQalNHWVgK"
    }
  }
}
